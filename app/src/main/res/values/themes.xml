<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SnapFloat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSecondary">@color/accentDark</item>
        <item name="android:windowBackground">@color/surfaceSoft</item>
        <item name="android:navigationBarColor">@color/surfaceSoft</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
    </style>

    <style name="Theme.SnapFloat.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Widget.SnapFloat.PrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/canvas</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingVertical">14dp</item>
    </style>

    <style name="Widget.SnapFloat.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/ink</item>
        <item name="android:textColor">@color/ink</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingVertical">14dp</item>
    </style>

    <style name="Widget.SnapFloat.FloatingCaptureButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/ink</item>
        <item name="android:textColor">@color/canvas</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingLeft">22dp</item>
        <item name="android:paddingRight">22dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
